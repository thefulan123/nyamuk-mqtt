# Nyamuk Environment Configuration
# Copy this file to .env and modify as needed

# MQTT Broker Settings
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic Configuration
TOPIC_PREFIX=nyamuk

# Web Dashboard Settings
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=change-me-in-production

# Web Dashboard Credentials
WEB_ADMIN_USER=admin
WEB_ADMIN_PASS=nyamuk123

# Docker Settings
DOCKER_CONTAINER_NAME=mosquitto
DOCKER_IMAGE=eclipse-mosquitto:2

# Application Settings
LOG_LEVEL=INFO
AUTO_REFRESH_INTERVAL=5
